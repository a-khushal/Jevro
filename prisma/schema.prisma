generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String            @id @default(uuid())
  tenantId    String
  name        String
  environment String
  principalType String @default("agent")
  createdAt   DateTime          @default(now())
  deletedAt   DateTime?
  policies    Policy[]
  auditEvents AuditEvent[]
  approvals   ApprovalRequest[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model Policy {
  id          String   @id @default(uuid())
  tenantId    String
  agentId     String
  connector   String
  actions     String[]
  environment String
  effect      String
  priority    Int      @default(100)
  dryRun      Boolean  @default(false)
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentId])
  @@index([tenantId, agentId, connector, environment])
  @@index([tenantId, priority])
  @@index([tenantId, deletedAt])
}

model AuditEvent {
  id        String   @id @default(uuid())
  tenantId  String
  agentId   String?
  eventType String
  connector String?
  action    String?
  status    String
  timestamp DateTime @default(now())
  details   Json
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agentId])
  @@index([eventType])
  @@index([timestamp])
}

model ApprovalRequest {
  id         String   @id @default(uuid())
  tenantId   String
  agentId    String
  connector  String
  action     String
  status     String
  requiredApprovals Int      @default(1)
  approvedBy String[]
  riskLevel  String   @default("low")
  requestedAt DateTime
  expiresAt  DateTime
  resolvedAt DateTime?
  resolvedBy String?
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentId])
  @@index([status])
  @@index([resolvedAt])
}

model ConnectorCredential {
  id         String   @id @default(uuid())
  tenantId   String
  connector  String
  token      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, connector])
  @@index([tenantId])
}

model SigningKey {
  id           String    @id @default(uuid())
  kid          String    @unique
  secret       String
  isActive     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  activatedAt  DateTime?
  deactivatedAt DateTime?

  @@index([isActive])
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  tenantId  String
  agentId   String
  reason    String?
  revokedAt DateTime @default(now())
  expiresAt DateTime

  @@index([tenantId])
  @@index([expiresAt])
}

model TenantConfig {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tokenTtlSeconds Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IdempotencyRecord {
  id             String   @id @default(uuid())
  tenantId       String
  agentId        String
  connector      String
  action         String
  idempotencyKey String
  requestHash    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([tenantId, agentId, connector, action, idempotencyKey])
  @@index([expiresAt])
}
