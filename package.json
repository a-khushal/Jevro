{
  "name": "new-folder",
  "version": "1.0.0",
  "description": "Okta for Agents MVP scaffold",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -w -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "prisma:migrate:status": "prisma migrate status",
    "loadtest": "node scripts/loadtest.js",
    "seed": "tsx scripts/seed.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:db": "REQUIRE_DB_TESTS=1 tsx --test --test-concurrency=1 \"src/**/*.test.ts\"",
    "test:with-db": "bash scripts/test-with-db.sh",
    "example:agent": "tsx examples/agent-ts/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "autocannon": "^8.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "prisma": "^6.16.2",
    "zod": "^4.3.6"
  }
}
